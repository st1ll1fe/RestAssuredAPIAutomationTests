{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name", "status"],
  "properties": {
    "id": {"type": "integer"},
    "name": {"type": "string"},
    "category": {
      "type": ["object", "null"],
      "properties": {
        "id": {"type": "integer"},
        "name": {"type": "string"}
      },
      "additionalProperties": false
    },
    "photoUrls": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "status": {"type": "string"}
  },
  "additionalProperties": false
}
